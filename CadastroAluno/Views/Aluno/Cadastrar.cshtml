@model CadastroAluno.Models.Aluno

@{
    ViewData["Title"] = "Cadastro de Aluno";
}

<div class="cadastro-container">
    <div class="cadastro-card">
        <div class="cadastro-header">
            <div class="header-icon">🎓</div>
            <h1>Cadastro de Aluno</h1>
            <p>Preencha os dados abaixo para realizar seu cadastro</p>
        </div>

        <form asp-action="Cadastrar" method="post" class="cadastro-form">
            <div class="form-group">
                <label asp-for="Nome"></label>
                <input asp-for="Nome" class="form-control" placeholder="Ex: João da Silva" />
                <span asp-validation-for="Nome" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="Ex: joao@email.com" />
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label asp-for="RA"></label>
                    <input asp-for="RA" class="form-control" placeholder="Ex: 123456" />
                    <span asp-validation-for="RA" class="validation-error"></span>
                </div>

                <div class="form-group half">
                    <label asp-for="DataNascimento"></label>
                    <input asp-for="DataNascimento" class="form-control" type="date" />
                    <span asp-validation-for="DataNascimento" class="validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Curso"></label>
                <input asp-for="Curso" class="form-control" placeholder="Ex: Análise e Desenvolvimento de Sistemas" />
                <span asp-validation-for="Curso" class="validation-error"></span>
            </div>

            <button type="submit" class="btn-cadastrar">
                <span>Cadastrar</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </button>
        </form>
    </div>
</div>
