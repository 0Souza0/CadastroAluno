@model CadastroAluno.Models.Aluno

@{
    ViewData["Title"] = "Cadastro Realizado";
}

<div class="confirmacao-container">
    <div class="confirmacao-card">
        <div class="success-icon">✅</div>
        <h1>Cadastro Realizado com Sucesso!</h1>
        <p class="confirmacao-subtitle">Confira os dados cadastrados abaixo</p>

        <div class="dados-aluno">
            <div class="dado-item">
                <span class="dado-label">Nome Completo</span>
                <span class="dado-valor">@Model.Nome</span>
            </div>
            <div class="dado-item">
                <span class="dado-label">E-mail</span>
                <span class="dado-valor">@Model.Email</span>
            </div>
            <div class="dado-item">
                <span class="dado-label">RA</span>
                <span class="dado-valor">@Model.RA</span>
            </div>
            <div class="dado-item">
                <span class="dado-label">Curso</span>
                <span class="dado-valor">@Model.Curso</span>
            </div>
            <div class="dado-item">
                <span class="dado-label">Data de Nascimento</span>
                <span class="dado-valor">@Model.DataNascimento.ToString("dd/MM/yyyy")</span>
            </div>
        </div>

        <a asp-action="Cadastrar" class="btn-novo-cadastro">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <span>Cadastrar outro aluno</span>
        </a>
    </div>
</div>
